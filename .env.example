# ===========================================
# COMPASS PLATFORM ENVIRONMENT CONFIGURATION
# ===========================================

# App
APP_ENV=development
APP_URL=http://localhost:8000
APP_SECRET=your-secret-key-min-32-chars-long

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgres://compass:compass@localhost:5432/compass
DATABASE_POOL_SIZE=10

# Redis (Job Queue + Caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Object Storage (MinIO / S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RASTER=compass-rasters
S3_BUCKET_MEDIA=compass-media
S3_BUCKET_AUDIO=compass-audio

# Gemini AI (required for AI features)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Sarvam AI (optional - for translation & TTS)
# Get key: https://sarvam.ai/
SARVAM_API_KEY=
SARVAM_API_URL=https://api.sarvam.ai/v1

# Satellite Data APIs (All Free!)
# Primary: Element 84 Earth Search (no auth required)
# Fallback: Copernicus Data Space (free): https://dataspace.copernicus.eu/
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# Market Price APIs (optional)
# data.gov.in API key (free): https://data.gov.in/
DATA_GOV_API_KEY=

# Maps (optional)
# Ola Maps: https://maps.olakrutrim.com/
OLA_MAPS_API_KEY=

# Feature Flags
MOCK_SATELLITE_DATA=false
ENABLE_SMS_OTP=false
ENABLE_VOICE_ALERTS=true

# Tenant Config
DEFAULT_TENANT_ID=default

# YouTube API (for Video Reels)
# Get key: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Facebook Videos (optional - only if you want Facebook video reels)
# Get access token: https://developers.facebook.com/
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_IDS=

# Google Cloud Speech-to-Text (optional - preferred voice intake provider;
# falls back to Gemini audio, then a labeled mock, when unset)
GOOGLE_STT_API_KEY=

# Optional backup Gemini key — the client rotates to this automatically
# when the primary key hits its quota (HTTP 429)
GEMINI_API_KEY_ALT=
